generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Tenants
// ============================================================

model Tenant {
  id               String    @id @default(uuid())
  name             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(255)
  status           String    @default("active") @db.VarChar(50)
  subscriptionTier String    @default("free") @map("subscription_tier") @db.VarChar(50)
  config           Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  users                User[]
  roles                Role[]
  permissions          Permission[]
  categories           Category[]
  attributeDefinitions AttributeDefinition[]
  skus                 Sku[]
  skuHistory           SkuHistory[]
  skuIssues            SkuIssue[]
  dataImports          DataImport[]
  reports              Report[]
  auditLogs            AuditLog[]
  webhooks             Webhook[]

  @@map("tenants")
}

// ============================================================
// Users & Auth
// ============================================================

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String    @db.VarChar(255)
  username     String?   @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String?   @map("first_name") @db.VarChar(100)
  lastName     String?   @map("last_name") @db.VarChar(100)
  avatarUrl    String?   @map("avatar_url")
  status       String    @default("active") @db.VarChar(50)
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLogin    DateTime? @map("last_login")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  userRoles    UserRole[]
  skusCreated  Sku[]        @relation("SkuCreatedBy")
  skusUpdated  Sku[]        @relation("SkuUpdatedBy")
  skuHistory   SkuHistory[]
  skuFavorites SkuFavorite[]
  skuIssues    SkuIssue[]
  dataImports  DataImport[]
  reports      Report[]
  auditLogs    AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  userRoles   UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(100)
  resource  String   @db.VarChar(100)
  action    String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, resource, action])
  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// Product Catalog
// ============================================================

model Category {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  parentCategoryId String?   @map("parent_category_id")
  name             String    @db.VarChar(255)
  slug             String    @db.VarChar(255)
  description      String?
  level            Int       @default(0)
  displayOrder     Int?      @map("display_order")
  attributes       Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  parent               Category?             @relation("CategoryChildren", fields: [parentCategoryId], references: [id])
  children             Category[]            @relation("CategoryChildren")
  attributeDefinitions AttributeDefinition[]
  skus                 Sku[]

  @@unique([tenantId, slug])
  @@index([tenantId, parentCategoryId])
  @@map("categories")
}

model AttributeDefinition {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  categoryId   String   @map("category_id")
  name         String   @db.VarChar(255)
  type         String   @db.VarChar(50)
  isRequired   Boolean  @default(false) @map("is_required")
  isSearchable Boolean  @default(true) @map("is_searchable")
  isFacetable  Boolean  @default(true) @map("is_facetable")
  isEditable   Boolean  @default(true) @map("is_editable")
  options      Json?
  validation   Json?
  displayOrder Int?     @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  skuAttributes SkuAttribute[]

  @@unique([tenantId, categoryId, name])
  @@index([tenantId, categoryId])
  @@map("attribute_definitions")
}

model Sku {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  categoryId     String    @map("category_id")
  skuCode        String    @map("sku_code") @db.VarChar(255)
  name           String    @db.VarChar(500)
  description    String?
  baseAttributes Json?     @map("base_attributes")
  pricing        Json?
  stockLevel     Int       @default(0) @map("stock_level")
  status         String    @default("active") @db.VarChar(50)
  createdBy      String    @map("created_by")
  updatedBy      String    @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  category          Category          @relation(fields: [categoryId], references: [id])
  creator           User              @relation("SkuCreatedBy", fields: [createdBy], references: [id])
  updater           User              @relation("SkuUpdatedBy", fields: [updatedBy], references: [id])
  attributes        SkuAttribute[]
  history           SkuHistory[]
  media             SkuMedia[]
  relationshipsFrom SkuRelationship[] @relation("SkuRelationshipFrom")
  relationshipsTo   SkuRelationship[] @relation("SkuRelationshipTo")
  favorites         SkuFavorite[]
  issues            SkuIssue[]

  @@unique([tenantId, skuCode])
  @@index([tenantId, categoryId])
  @@index([tenantId, status])
  @@map("skus")
}

model SkuAttribute {
  id          String   @id @default(uuid())
  skuId       String   @map("sku_id")
  attributeId String   @map("attribute_id")
  value       String?
  valueNumber Decimal? @map("value_number") @db.Decimal(20, 6)
  valueDate   DateTime? @map("value_date") @db.Date
  valueJson   Json?    @map("value_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sku                 Sku                 @relation(fields: [skuId], references: [id], onDelete: Cascade)
  attributeDefinition AttributeDefinition @relation(fields: [attributeId], references: [id])

  @@unique([skuId, attributeId])
  @@index([attributeId, value])
  @@map("sku_attributes")
}

model SkuHistory {
  id         String   @id @default(uuid())
  skuId      String   @map("sku_id")
  tenantId   String   @map("tenant_id")
  changedBy  String   @map("changed_by")
  changes    Json
  changeType String   @map("change_type") @db.VarChar(50)
  changedAt  DateTime @default(now()) @map("changed_at")

  sku    Sku    @relation(fields: [skuId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [changedBy], references: [id])

  @@index([skuId, changedAt])
  @@map("sku_history")
}

model SkuMedia {
  id           String   @id @default(uuid())
  skuId        String   @map("sku_id")
  type         String   @db.VarChar(50)
  url          String
  altText      String?  @map("alt_text")
  displayOrder Int?     @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  sku Sku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
  @@map("sku_media")
}

model SkuRelationship {
  id               String @id @default(uuid())
  skuIdFrom        String @map("sku_id_from")
  skuIdTo          String @map("sku_id_to")
  relationshipType String @map("relationship_type") @db.VarChar(50)

  skuFrom Sku @relation("SkuRelationshipFrom", fields: [skuIdFrom], references: [id])
  skuTo   Sku @relation("SkuRelationshipTo", fields: [skuIdTo], references: [id])

  @@unique([skuIdFrom, skuIdTo, relationshipType])
  @@map("sku_relationships")
}

model SkuFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  skuId     String   @map("sku_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sku  Sku  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([userId, skuId])
  @@index([userId])
  @@map("sku_favorites")
}

model SkuIssue {
  id          String   @id @default(uuid())
  skuId       String   @map("sku_id")
  tenantId    String   @map("tenant_id")
  reportedBy  String   @map("reported_by")
  issueType   String   @map("issue_type") @db.VarChar(100)
  description String
  status      String   @default("open") @db.VarChar(50)
  resolution  String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sku      Sku    @relation(fields: [skuId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  reporter User   @relation(fields: [reportedBy], references: [id])

  @@index([skuId, status])
  @@map("sku_issues")
}

// ============================================================
// Data Imports
// ============================================================

model DataImport {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  initiatedBy   String    @map("initiated_by")
  fileName      String    @map("file_name") @db.VarChar(255)
  fileUrl       String?   @map("file_url")
  status        String    @default("pending") @db.VarChar(50)
  totalRows     Int?      @map("total_rows")
  processedRows Int       @default(0) @map("processed_rows")
  failedRows    Int       @default(0) @map("failed_rows")
  metadata      Json?
  errorSummary  Json?     @map("error_summary")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  initiator     User          @relation(fields: [initiatedBy], references: [id])
  importErrors  ImportError[]

  @@index([tenantId, status])
  @@map("data_imports")
}

model ImportError {
  id           String   @id @default(uuid())
  importId     String   @map("import_id")
  rowNumber    Int      @map("row_number")
  columnName   String?  @map("column_name") @db.VarChar(255)
  errorMessage String   @map("error_message")
  errorType    String   @map("error_type") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")

  dataImport DataImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@map("import_errors")
}

// ============================================================
// Reports
// ============================================================

model Report {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  createdBy  String    @map("created_by")
  name       String    @db.VarChar(255)
  reportType String    @map("report_type") @db.VarChar(100)
  filters    Json?
  columns    Json?
  format     String    @db.VarChar(50)
  fileUrl    String?   @map("file_url")
  status     String    @default("generating") @db.VarChar(50)
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  creator User   @relation(fields: [createdBy], references: [id])

  @@index([tenantId, status])
  @@map("reports")
}

// ============================================================
// Audit Logs
// ============================================================

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String?  @map("resource_id")
  action       String   @db.VarChar(50)
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent")
  timestamp    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, timestamp])
  @@index([tenantId, resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================
// Webhooks
// ============================================================

model Webhook {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  url       String
  events    String[]
  active    Boolean  @default(true)
  headers   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, active])
  @@map("webhooks")
}
